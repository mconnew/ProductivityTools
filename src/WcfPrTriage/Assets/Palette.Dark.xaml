<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Dark palette. Swapped in/out at runtime by ThemeManager; every neutral/status colour in the
       app is referenced through these keys via DynamicResource, so replacing this dictionary retints
       the whole UI live. Keep the key set identical to Palette.Light.xaml. -->
  <SolidColorBrush x:Key="BgBrush" Color="#FF1E1F22" />
  <SolidColorBrush x:Key="PanelBrush" Color="#FF26282C" />
  <SolidColorBrush x:Key="PanelAltBrush" Color="#FF2E3136" />
  <SolidColorBrush x:Key="BorderBrush" Color="#FF3A3D42" />
  <SolidColorBrush x:Key="TextBrush" Color="#FFECECEC" />
  <SolidColorBrush x:Key="MutedTextBrush" Color="#FF9AA0A6" />
  <SolidColorBrush x:Key="AccentBrush" Color="#FF3B82F6" />
  <SolidColorBrush x:Key="SelectionBrush" Color="#FF33405A" />

  <SolidColorBrush x:Key="FailureBrush" Color="#FFF04747" />
  <SolidColorBrush x:Key="SuccessBrush" Color="#FF57B65B" />
  <SolidColorBrush x:Key="RunningBrush" Color="#FFE3B341" />
  <SolidColorBrush x:Key="UnknownBrush" Color="#FF6B7078" />

</ResourceDictionary>
