<Window x:Class="WcfPrTriage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WcfPrTriage.ViewModels"
        Title="WCF PR Triage" Height="820" Width="1280"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBrush}"
        TextElement.Foreground="{DynamicResource TextBrush}"
        FontFamily="Segoe UI" FontSize="13"
        Loaded="Window_Loaded">

  <Window.DataContext>
    <vm:MainViewModel />
  </Window.DataContext>

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <!-- PR list row -->
    <DataTemplate x:Key="PrItemTemplate" DataType="{x:Type vm:PullRequestViewModel}">
      <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}">
        <Grid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Open PR in GitHub"
                      Command="{Binding PlacementTarget.Tag.OpenPrExternalCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <MenuItem Header="Open build in Azure DevOps"
                      Command="{Binding PlacementTarget.Tag.OpenBuildInDevOpsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <Separator />
            <MenuItem Header="Copy PR URL"
                      Command="{Binding PlacementTarget.Tag.CopyPrUrlCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
          </ContextMenu>
        </Grid.ContextMenu>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="{Binding StateGlyph}" FontSize="15" Margin="0,1,8,0"
                   VerticalAlignment="Top"
                   Foreground="{Binding State, Converter={StaticResource CiStateToBrushConverter}}" />
        <StackPanel Grid.Column="1">
          <TextBlock TextTrimming="CharacterEllipsis">
            <TextBlock.ToolTip>
              <ToolTip>
                <TextBlock TextWrapping="Wrap">
                  <Run Text="{Binding Header, Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" />
                  <Run Text="  " />
                  <Run Text="{Binding Title, Mode=OneWay}" />
                </TextBlock>
              </ToolTip>
            </TextBlock.ToolTip>
            <Run Text="{Binding Header, Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" />
            <Run Text="  " />
            <Run Text="{Binding Title, Mode=OneWay}" />
          </TextBlock>
          <TextBlock Text="{Binding SubHeader}" Foreground="{DynamicResource MutedTextBrush}" FontSize="11.5" Margin="0,2,0,0" />
        </StackPanel>
        <Button Grid.Column="2" Content="⟳" ToolTip="Refresh this PR (bypass cache)"
                Command="{Binding DataContext.RefreshPrCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                CommandParameter="{Binding}"
                VerticalAlignment="Top" Margin="6,0,0,0" Padding="6,1"
                Background="Transparent" BorderThickness="0"
                Foreground="{DynamicResource MutedTextBrush}" FontSize="14" Cursor="Hand" />
      </Grid>
    </DataTemplate>

    <!-- Failure tree node -->
    <HierarchicalDataTemplate DataType="{x:Type vm:TriageNodeViewModel}" ItemsSource="{Binding Children}">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="{Binding Glyph}" Margin="0,0,6,0" />
        <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
        <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource MutedTextBrush}" Margin="8,0,0,0"
                   FontSize="11.5" VerticalAlignment="Center" />
      </StackPanel>
    </HierarchicalDataTemplate>

    <Style x:Key="TriageItemContainerStyle" TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
      <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
      <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
    </Style>

    <!-- Shared pane header: fixed height keeps all three panes' headers (and the content/scrollbars
         below them) perfectly aligned regardless of whether the header holds text or buttons. -->
    <Style x:Key="PaneHeaderBorder" TargetType="Border">
      <Setter Property="Height" Value="42" />
      <Setter Property="Background" Value="{DynamicResource PanelAltBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="14,0" />
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- ===================== Top bar ===================== -->
    <Border Grid.Row="0" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1" Padding="14,10">
      <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="WCF PR Triage" FontSize="16" FontWeight="SemiBold" />
          <TextBlock Text="{Binding RepoLabel}" Foreground="{DynamicResource MutedTextBrush}" Margin="10,0,0,0" VerticalAlignment="Center" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
          <TextBlock Text="{Binding RateLimitText}" Foreground="{DynamicResource MutedTextBrush}"
                     VerticalAlignment="Center" Margin="0,0,14,0" />
          <Button Content="⟳ Refresh" Command="{Binding RefreshCommand}" Margin="0,0,8,0" />
          <Button Content="⚙ Settings" Command="{Binding OpenSettingsCommand}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- ===================== Body ===================== -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="330" MinWidth="240" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="420" MinWidth="260" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" MinWidth="280" />
      </Grid.ColumnDefinitions>

      <!-- PR list -->
      <DockPanel Grid.Column="0" Background="{DynamicResource BgBrush}">
        <Border DockPanel.Dock="Top" Style="{StaticResource PaneHeaderBorder}">
          <TextBlock Text="Open pull requests" FontWeight="SemiBold" VerticalAlignment="Center" />
        </Border>
        <Grid>
          <ListBox ItemsSource="{Binding PullRequests}"
                   SelectedItem="{Binding SelectedPr, Mode=TwoWay}"
                   ItemTemplate="{StaticResource PrItemTemplate}" />
          <TextBlock Text="Loading…" Foreground="{DynamicResource MutedTextBrush}"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Visibility="{Binding IsLoadingPrs, Converter={StaticResource BoolToVis}}" />
        </Grid>
      </DockPanel>

      <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                    Background="{DynamicResource BorderBrush}" />

      <!-- Failure tree -->
      <DockPanel Grid.Column="2" Background="{DynamicResource BgBrush}">
        <Border DockPanel.Dock="Top" Style="{StaticResource PaneHeaderBorder}">
          <Grid VerticalAlignment="Center">
            <TextBlock Text="Failures" FontWeight="SemiBold" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
              <TextBlock Text="Triaging…" Foreground="{DynamicResource RunningBrush}"
                         VerticalAlignment="Center" Margin="0,0,10,0"
                         Visibility="{Binding IsTriaging, Converter={StaticResource BoolToVis}}" />
              <Button Content="Open PR ↗" Command="{Binding OpenPrCommand}" Padding="10,3"
                      ToolTip="Open this pull request on GitHub" />
            </StackPanel>
          </Grid>
        </Border>
        <TreeView x:Name="FailureTree" ItemsSource="{Binding Nodes}"
                  ItemContainerStyle="{StaticResource TriageItemContainerStyle}"
                  SelectedItemChanged="FailureTree_SelectedItemChanged"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  VirtualizingPanel.ScrollUnit="Pixel"
                  Padding="6" />
      </DockPanel>

      <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"
                    Background="{DynamicResource BorderBrush}" />

      <!-- Detail pane -->
      <DockPanel Grid.Column="4" Background="{DynamicResource BgBrush}">
        <Border DockPanel.Dock="Top" Style="{StaticResource PaneHeaderBorder}">
          <Grid VerticalAlignment="Center">
            <TextBlock Text="{Binding DetailHeader}" FontWeight="SemiBold" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" Margin="0,0,150,0" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
              <Button Content="Copy" Command="{Binding CopyDetailCommand}" Padding="10,3" Margin="0,0,6,0" />
              <Button Content="Open ↗" Command="{Binding OpenNodeUrlCommand}" Padding="10,3" />
            </StackPanel>
          </Grid>
        </Border>
        <TextBox Text="{Binding DetailText, Mode=OneWay}" IsReadOnly="True"
                 FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12.5"
                 Background="{DynamicResource BgBrush}" BorderThickness="0"
                 TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 Padding="12,10,0,0" IsInactiveSelectionHighlightEnabled="True" />
      </DockPanel>
    </Grid>

    <!-- ===================== Status bar ===================== -->
    <Border Grid.Row="2" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0" Padding="14,6">
      <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource MutedTextBrush}" />
    </Border>
  </Grid>
</Window>
